{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/project-guardrails/control-registry.schema.json",
  "title": "Quality Control Registry",
  "type": "object",
  "required": ["schema_version", "controls", "capabilities", "baselines", "cleanup_debts", "design_scope_exemptions", "federated_rule_mappings"],
  "properties": {
    "schema_version": {"const": "2.0"},
    "controls": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id", "control_revision", "rule_refs", "title", "dimension", "project_requirement", "requirement_ids",
          "risk", "risk_ids", "verification_ids", "owner",
          "applies", "required_from_maturity", "scope", "evaluation_mode", "required_capability_refs", "execution", "evidence_required"
        ],
        "properties": {
          "id": {"type": "string", "pattern": "^[A-Z0-9][A-Z0-9._-]+$"},
          "control_revision": {"type": "string", "minLength": 1},
          "rule_refs": {"type": "array", "items": {"type": "string"}},
          "title": {"type": "string", "minLength": 1},
          "dimension": {"type": "string", "minLength": 1},
          "source_standard": {"type": "string"},
          "source_version": {"type": "string"},
          "project_requirement": {"type": "string", "minLength": 1},
          "requirement_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "risk": {"type": "string", "minLength": 1},
          "risk_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "verification_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "owner": {"type": "string", "minLength": 1},
          "applies": {"type": "boolean"},
          "applicability_rationale": {"type": "string"},
          "applicability_confirmed_by": {"type": "string"},
          "applicability_exemption_ref": {"type": "string"},
          "required_from_maturity": {
            "enum": ["prototype", "engineering_ready", "production_ready", "commercial_ready", "regulated_ready"]
          },
          "scope": {"type": "array", "items": {"type": "string"}},
          "evaluation_mode": {"enum": ["absolute", "ratchet_delta"]},
          "ratchet_policy": {
            "type": "object",
            "required": ["baseline_ref", "observation_path"],
            "properties": {
              "baseline_ref": {"type": "string", "minLength": 1},
              "observation_path": {"type": "string", "minLength": 1}
            },
            "additionalProperties": false
          },
          "required_capability_refs": {"type": "array", "items": {"type": "string"}},
          "execution": {
            "type": "object",
            "required": ["type", "authorization_required"],
            "properties": {
              "type": {"enum": ["command", "file_exists", "file_absent", "manual", "remote", "privileged"]},
              "command": {"type": "array", "items": {"type": "string"}},
              "path": {"type": "string"},
              "cwd": {"type": "string"},
              "timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 86400},
              "artifact_paths": {"type": "array", "items": {"type": "string"}},
              "authorization_required": {"type": "boolean"}
            },
            "additionalProperties": false
          },
          "evidence_required": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "manual_evidence": {
            "type": "object",
            "required": ["status", "actor", "authority_id", "evidence_ref", "evidence_sha256", "reviewed_at", "expires_at", "commit"],
            "properties": {
              "status": {"const": "PASS"},
              "actor": {"type": "string", "minLength": 1},
              "authority_id": {"type": "string", "minLength": 1},
              "evidence_ref": {"type": "string", "minLength": 1},
              "evidence_sha256": {"type": "string", "pattern": "^[a-fA-F0-9]{64}$"},
              "reviewed_at": {"type": "string", "format": "date-time"},
              "expires_at": {"type": "string", "format": "date-time"},
              "commit": {"type": "string", "minLength": 1}
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "owner", "authorization_required", "preflight"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "owner": {"type": "string", "minLength": 1},
          "authorization_required": {"type": "boolean"},
          "preflight": {
            "type": "object",
            "required": ["command"],
            "properties": {
              "command": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
              "cwd": {"type": "string"},
              "timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 3600}
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "baselines": {"type": "array", "items": {"$ref": "#/$defs/baseline"}},
    "cleanup_debts": {"type": "array", "items": {"$ref": "#/$defs/cleanupDebt"}},
    "design_scope_exemptions": {"type": "array", "items": {"$ref": "#/$defs/designScopeExemption"}},
    "federated_rule_mappings": {"type": "array", "items": {"$ref": "#/$defs/federatedRuleMapping"}}
  },
  "$defs": {
    "baseline": {
      "type": "object",
      "required": ["id", "control_id", "revision", "source_ref", "source_sha256", "violation_count"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "control_id": {"type": "string", "minLength": 1},
        "revision": {"type": "integer", "minimum": 1},
        "source_ref": {"type": "string", "minLength": 1},
        "source_sha256": {"type": "string", "pattern": "^[a-fA-F0-9]{64}$"},
        "violation_count": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "cleanupDebt": {
      "type": "object",
      "required": ["id", "control_id", "baseline_ref", "scope", "owner", "status", "delete_by", "rationale"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "control_id": {"type": "string", "minLength": 1},
        "baseline_ref": {"type": "string", "minLength": 1},
        "scope": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "owner": {"type": "string", "minLength": 1},
        "status": {"enum": ["open", "closed"]},
        "delete_by": {"type": "string", "format": "date-time"},
        "rationale": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "designScopeExemption": {
      "type": "object",
      "required": ["id", "control_id", "scope", "owner", "rationale", "alternative_control_refs", "status", "reviewed_at", "review_by"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "control_id": {"type": "string", "minLength": 1},
        "scope": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "owner": {"type": "string", "minLength": 1},
        "rationale": {"type": "string", "minLength": 1},
        "alternative_control_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "status": {"enum": ["active", "expired", "revoked"]},
        "reviewed_at": {"type": "string", "format": "date-time"},
        "review_by": {"type": "string", "format": "date-time"}
      },
      "additionalProperties": false
    },
    "federatedRuleMapping": {
      "type": "object",
      "required": ["rule_id", "source_ref", "source_sha256", "source_selector", "disposition", "semantic_owner", "control_refs", "mandatory", "status", "observed_at", "reviewed_at"],
      "properties": {
        "rule_id": {"type": "string", "minLength": 1},
        "source_ref": {"type": "string", "minLength": 1},
        "source_sha256": {"type": "string", "pattern": "^[a-fA-F0-9]{64}$"},
        "source_selector": {
          "type": "object",
          "required": ["kind", "value", "occurrence"],
          "properties": {
            "kind": {"enum": ["whole_file", "markdown_heading"]},
            "value": {"type": ["string", "null"]},
            "occurrence": {"type": ["integer", "null"], "minimum": 1}
          },
          "additionalProperties": false
        },
        "disposition": {"enum": ["federated", "migrated", "compiled", "retired"]},
        "semantic_owner": {"type": "string", "minLength": 1},
        "control_refs": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "mandatory": {"type": "boolean"},
        "status": {"enum": ["current", "stale", "disputed", "unmapped"]},
        "observed_at": {"type": "string", "format": "date-time"},
        "reviewed_at": {"type": ["string", "null"], "format": "date-time"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
