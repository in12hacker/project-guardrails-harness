{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/project-guardrails/quality-manifest.schema.json",
  "title": "Project Quality Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "project",
    "profile",
    "scope",
    "authority",
    "audit_policy"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "project": {
      "type": "object",
      "required": ["name", "root", "development_mode", "target_maturity"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "root": {"type": "string", "minLength": 1},
        "development_mode": {
          "enum": ["ai_greenfield", "ai_brownfield", "human_greenfield", "human_brownfield"]
        },
        "target_maturity": {
          "enum": ["prototype", "engineering_ready", "production_ready", "commercial_ready", "regulated_ready"]
        }
      },
      "additionalProperties": true
    },
    "profile": {
      "type": "object",
      "required": ["product_types", "distribution_model", "target_markets", "criticality", "data_sensitivity", "deployment_models", "support_model", "primary_users", "ai_system", "legal_profiles"],
      "properties": {
        "product_types": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "distribution_model": {
          "enum": ["open_source", "private_commercial", "saas", "client_software", "embedded", "mixed"]
        },
        "target_markets": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "criticality": {"enum": ["low", "medium", "high", "critical"]},
        "data_sensitivity": {"enum": ["public", "internal", "confidential", "restricted", "regulated"]},
        "deployment_models": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "support_model": {"enum": ["community", "best_effort", "contracted", "managed", "none"]},
        "primary_users": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "ai_system": {"type": "boolean"},
        "legal_profiles": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "quality_dimensions": {"type": "array", "minItems": 1, "items": {"type": "string"}}
      },
      "additionalProperties": true
    },
    "scope": {
      "type": "object",
      "required": ["mode", "included_paths", "excluded_paths", "overall_project_claim_allowed"],
      "properties": {
        "mode": {"enum": ["full_repo", "subproject"]},
        "included_paths": {"type": "array", "items": {"type": "string"}},
        "excluded_paths": {"type": "array", "items": {"type": "string"}},
        "unassessed_dependencies": {"type": "array", "items": {"type": "string"}},
        "overall_project_claim_allowed": {"type": "boolean"}
      },
      "additionalProperties": true
    },
    "authority": {
      "type": "object",
      "required": ["local_unprivileged_controls", "separate_authorization_required"],
      "properties": {
        "local_unprivileged_controls": {"type": "boolean"},
        "separate_authorization_required": {
          "type": "array",
          "items": {"enum": ["dependency_install", "paid_service", "secrets", "remote_mutation", "production_mutation", "privileged_execution"]}
        }
      },
      "additionalProperties": false
    },
    "audit_policy": {
      "type": "object",
      "required": ["required_stages", "independent_actors"],
      "properties": {
        "required_stages": {
          "type": "array",
          "minItems": 1,
          "items": {"enum": ["self", "cross", "release_authority", "third_party"]}
        },
        "independent_actors": {"const": true}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
