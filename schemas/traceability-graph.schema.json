{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/project-guardrails/traceability-graph.schema.json",
  "title": "Derived Quality Traceability Graph",
  "type": "object",
  "required": ["schema_version", "generated_from_registry_sha256", "links"],
  "properties": {
    "schema_version": {"const": "2.0"},
    "generated_from_registry_sha256": {"type": "string", "minLength": 64, "maxLength": 64},
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["requirement_ids", "risk_ids", "control_id", "verification_ids", "evidence_required"],
        "properties": {
          "requirement_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "risk_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "control_id": {"type": "string"},
          "verification_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "evidence_required": {"type": "array", "minItems": 1, "items": {"type": "string"}}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
