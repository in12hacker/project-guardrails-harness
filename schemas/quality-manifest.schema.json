{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/project-guardrails/quality-manifest.schema.json",
  "title": "Project Quality Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "project",
    "profile",
    "scope",
    "authority",
    "audit_policy",
    "development_policy",
    "claim_policies"
  ],
  "properties": {
    "schema_version": {"const": "2.0"},
    "project": {
      "type": "object",
      "required": ["name", "root", "development_mode", "target_maturity"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "root": {"type": "string", "minLength": 1},
        "development_mode": {
          "enum": ["ai_greenfield", "ai_brownfield", "human_greenfield", "human_brownfield"]
        },
        "target_maturity": {
          "enum": ["prototype", "engineering_ready", "production_ready", "commercial_ready", "regulated_ready"]
        }
      },
      "additionalProperties": false
    },
    "profile": {
      "type": "object",
      "required": ["product_types", "distribution_model", "target_markets", "criticality", "data_sensitivity", "deployment_models", "support_model", "primary_users", "public_contracts", "build_topology", "persistent_state", "external_contributions", "ai_system", "legal_profiles"],
      "properties": {
        "product_types": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "distribution_model": {
          "enum": ["open_source", "open_core", "private_commercial", "saas", "client_software", "embedded", "mixed"]
        },
        "target_markets": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "criticality": {"enum": ["low", "medium", "high", "critical"]},
        "data_sensitivity": {"enum": ["public", "internal", "confidential", "restricted", "regulated"]},
        "deployment_models": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "support_model": {"enum": ["community", "best_effort", "contracted", "managed", "none"]},
        "primary_users": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "public_contracts": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"enum": ["none", "library_api", "service_api", "wire_protocol", "extension_api", "plugin_api", "file_format"]},
          "not": {
            "allOf": [
              {"contains": {"const": "none"}},
              {"minItems": 2}
            ]
          }
        },
        "build_topology": {"enum": ["single_form", "multi_form", "cross_target"]},
        "persistent_state": {"enum": ["none", "database", "indexed_store", "on_disk_format", "client_state", "mixed"]},
        "external_contributions": {"enum": ["accepted", "restricted", "closed"]},
        "ai_system": {"type": "boolean"},
        "legal_profiles": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "quality_dimensions": {"type": "array", "minItems": 1, "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "scope": {
      "type": "object",
      "required": ["mode", "included_paths", "excluded_paths", "overall_project_claim_allowed"],
      "properties": {
        "mode": {"enum": ["full_repo", "subproject"]},
        "included_paths": {"type": "array", "items": {"type": "string"}},
        "excluded_paths": {"type": "array", "items": {"type": "string"}},
        "unassessed_dependencies": {"type": "array", "items": {"type": "string"}},
        "overall_project_claim_allowed": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "authority": {
      "type": "object",
      "required": ["local_unprivileged_controls", "separate_authorization_required"],
      "properties": {
        "local_unprivileged_controls": {"type": "boolean"},
        "separate_authorization_required": {
          "type": "array",
          "items": {"enum": ["dependency_install", "paid_service", "secrets", "remote_mutation", "production_mutation", "privileged_execution"]}
        }
      },
      "additionalProperties": false
    },
    "audit_policy": {
      "type": "object",
      "required": ["required_stages", "independent_authorities", "authorities"],
      "properties": {
        "required_stages": {
          "type": "array",
          "minItems": 1,
          "items": {"enum": ["self", "cross", "release_authority", "third_party"]}
        },
        "independent_authorities": {"const": true},
        "authorities": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "kind", "identity_ref", "owner", "allowed_stages"],
            "properties": {
              "id": {"type": "string", "minLength": 1},
              "kind": {"enum": ["virtual_role", "human", "ci", "external"]},
              "identity_ref": {"type": "string", "minLength": 1},
              "owner": {"type": "string", "minLength": 1},
              "allowed_stages": {
                "type": "array",
                "minItems": 1,
                "items": {"enum": ["self", "cross", "release_authority", "third_party"]}
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "development_policy": {
      "type": "object",
      "required": ["active_campaign"],
      "properties": {
        "active_campaign": {
          "type": ["object", "null"],
          "required": ["id", "revision", "baseline_commit", "baseline_registry_sha256", "baseline_workspace_sha256", "target_maturity", "assessed_scope", "owner", "phases"],
          "properties": {
            "id": {"type": "string", "minLength": 1},
            "revision": {"type": "integer", "minimum": 1},
            "baseline_commit": {"type": "string", "minLength": 1},
            "baseline_registry_sha256": {"type": "string", "minLength": 64, "maxLength": 64},
            "baseline_workspace_sha256": {"type": "string", "minLength": 64, "maxLength": 64},
            "target_maturity": {"enum": ["prototype", "engineering_ready", "production_ready", "commercial_ready", "regulated_ready"]},
            "assessed_scope": {"type": "array", "minItems": 1, "items": {"type": "string"}},
            "owner": {"type": "string", "minLength": 1},
            "phases": {
              "type": "array",
              "minItems": 1,
              "items": {"$ref": "#/$defs/campaignPhase"}
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "claim_policies": {
      "type": "object",
      "required": ["task", "phase", "project", "release"],
      "properties": {
        "task": {"$ref": "#/$defs/claimPolicy"},
        "phase": {"$ref": "#/$defs/claimPolicy"},
        "project": {"$ref": "#/$defs/claimPolicy"},
        "release": {"$ref": "#/$defs/claimPolicy"}
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "claimPolicy": {
      "type": "object",
      "required": ["required_stages"],
      "properties": {
        "required_stages": {
          "type": "array",
          "minItems": 1,
          "items": {"enum": ["self", "cross", "release_authority", "third_party"]}
        }
      },
      "additionalProperties": false
    },
    "exitPolicy": {
      "type": "object",
      "required": ["max_new_violations", "minimum_fixed_violations", "allow_open_cleanup_debt"],
      "properties": {
        "max_new_violations": {"type": "integer", "minimum": 0},
        "minimum_fixed_violations": {"type": "integer", "minimum": 0},
        "allow_open_cleanup_debt": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "campaignTask": {
      "type": "object",
      "required": ["id", "kind", "affected_control_ids", "assessed_scope", "exit_policy"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "kind": {"enum": ["debt_reduction", "framework_adoption", "correctness_fix"]},
        "affected_control_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "assessed_scope": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "exit_policy": {"$ref": "#/$defs/exitPolicy"}
      },
      "additionalProperties": false
    },
    "campaignPhase": {
      "type": "object",
      "required": ["id", "title", "affected_control_ids", "assessed_scope", "exit_policy", "tasks"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "title": {"type": "string", "minLength": 1},
        "affected_control_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "assessed_scope": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "exit_policy": {"$ref": "#/$defs/exitPolicy"},
        "tasks": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/campaignTask"}}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
