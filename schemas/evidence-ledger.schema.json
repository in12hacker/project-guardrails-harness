{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/project-guardrails/evidence-ledger.schema.json",
  "title": "Quality Evidence Ledger",
  "type": "object",
  "required": ["schema_version", "runs", "audits", "claims"],
  "properties": {
    "schema_version": {"const": "2.0"},
    "runs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["run_id", "timestamp", "commit", "workspace_sha256", "target_maturity", "registry_sha256", "selected_control_ids", "audit_stage", "results", "conclusion", "previous_entry_sha256", "entry_sha256"],
        "properties": {
          "run_id": {"type": "string"},
          "timestamp": {"type": "string", "format": "date-time"},
          "commit": {"type": "string"},
          "workspace_sha256": {"type": "string", "minLength": 64, "maxLength": 64},
          "target_maturity": {"type": "string"},
          "registry_sha256": {"type": "string", "minLength": 64, "maxLength": 64},
          "selected_control_ids": {"type": "array", "items": {"type": "string"}},
          "audit_stage": {"enum": ["self", "cross", "release_authority", "third_party"]},
          "results": {"type": "array"},
          "conclusion": {"enum": ["PASS", "FAIL", "BLOCKED", "DISPUTED"]},
          "previous_entry_sha256": {"type": "string"},
          "entry_sha256": {"type": "string", "minLength": 64, "maxLength": 64}
        },
        "additionalProperties": true
      }
    },
    "audits": {"type": "array"},
    "claims": {"type": "array"}
  },
  "additionalProperties": false
}
