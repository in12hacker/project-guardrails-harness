{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/project-guardrails/control-registry.schema.json",
  "title": "Quality Control Registry",
  "type": "object",
  "required": ["schema_version", "controls", "capabilities", "baselines", "cleanup_debts", "design_scope_exemptions", "federated_rule_mappings"],
  "properties": {
    "schema_version": {"const": "2.0"},
    "controls": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id", "control_revision", "rule_refs", "title", "dimension", "project_requirement", "requirement_ids",
          "risk", "risk_ids", "verification_ids", "owner",
          "applies", "required_from_maturity", "scope", "evaluation_mode", "required_capability_refs", "execution", "evidence_required"
        ],
        "properties": {
          "id": {"type": "string", "pattern": "^[A-Z0-9][A-Z0-9._-]+$"},
          "control_revision": {"type": "string", "minLength": 1},
          "rule_refs": {"type": "array", "items": {"type": "string"}},
          "title": {"type": "string", "minLength": 1},
          "dimension": {"type": "string", "minLength": 1},
          "source_standard": {"type": "string"},
          "source_version": {"type": "string"},
          "project_requirement": {"type": "string", "minLength": 1},
          "requirement_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "risk": {"type": "string", "minLength": 1},
          "risk_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "verification_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "owner": {"type": "string", "minLength": 1},
          "applies": {"type": "boolean"},
          "applicability_rationale": {"type": "string"},
          "required_from_maturity": {
            "enum": ["prototype", "engineering_ready", "production_ready", "commercial_ready", "regulated_ready"]
          },
          "scope": {"type": "array", "items": {"type": "string"}},
          "evaluation_mode": {"enum": ["absolute", "ratchet_delta"]},
          "required_capability_refs": {"type": "array", "items": {"type": "string"}},
          "execution": {
            "type": "object",
            "required": ["type", "authorization_required"],
            "properties": {
              "type": {"enum": ["command", "file_exists", "file_absent", "manual", "remote", "privileged"]},
              "command": {"type": "array", "items": {"type": "string"}},
              "path": {"type": "string"},
              "cwd": {"type": "string"},
              "timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 86400},
              "artifact_paths": {"type": "array", "items": {"type": "string"}},
              "authorization_required": {"type": "boolean"}
            },
            "additionalProperties": true
          },
          "evidence_required": {"type": "array", "minItems": 1, "items": {"type": "string"}}
        },
        "additionalProperties": true
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "owner", "authorization_required", "preflight"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "owner": {"type": "string", "minLength": 1},
          "authorization_required": {"type": "boolean"},
          "preflight": {
            "type": "object",
            "required": ["command"],
            "properties": {
              "command": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
              "cwd": {"type": "string"},
              "timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 3600}
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "baselines": {"type": "array"},
    "cleanup_debts": {"type": "array"},
    "design_scope_exemptions": {"type": "array"},
    "federated_rule_mappings": {"type": "array"}
  },
  "additionalProperties": false
}
